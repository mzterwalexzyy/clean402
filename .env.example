# Service (payTo) wallet — receives x402 payments; owns the facilitator API key
WALLET_PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...

# Facilitator API key from https://x402.celo.org (X-API-Key on /verify + /settle)
FACILITATOR_API_KEY=x402_...

# Demand agent (payer) wallet — holds USDC, pays per request
PAYER_PRIVATE_KEY=0x...
PAYER_ADDRESS=0x...

# Assigned ERC-8021 attribution tag from Celo Builders registration (celo_ + 12 hex)
ATTRIBUTION_TAG=

# Server
PORT=4021
PUBLIC_URL=http://localhost:4021

# Optional: Groq API key for AI-polish mode (deterministic cleaner works without it)
GROQ_API_KEY=
